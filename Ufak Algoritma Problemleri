#region Problem 2
//Belirlenen kullanıcı adı ve şifre doğru girildiğinde "Giriş Başarılı" yanlış girildiğinde "Kullanıcı adı veya şifre hatalı" mesajı veren Console uygulamasını yapalım.
Console.Write("Kullanıcı adı giriniz.");
string kullaniciAdi = Console.ReadLine();
Console.Write("Şifre giriniz.");
string sifre = Console.ReadLine();
if (kullaniciAdi == "Ali" && sifre == "4444")
    Console.WriteLine("Giriş Başarılı");
else
    Console.WriteLine("Kullanıcı adı veya şifre hatalı");
//Ekstra kritik notları:Bu yapılandırmayı biz switch ile de kurabiliriz eşitlik durumu kontrol edildiği için ayrıca ben scope kullanmadan yaptım tek satır olduğu için ama scopelu da yapılabilir.
Console.WriteLine(kullaniciAdi == "Ali" && sifre == "4444" ? "Giriş Başarılı" : "Kullanıcı adı veya şifre hatalı"); //Bu yapı ile koca if bloğunu tek satırda yazabilirim.
#endregion

#region Problem 3
//Kullanıcıdan alınan iki sayının ve yapılacak işlem türünün seçilmesiyle sonucu hesaplayan programı yazalım (Hesap Makinesi)
Console.Write("Lütfen istediğiniz işlemi seçiniz : ");
Console.Write("------------MENU--------------");
Console.Write("1-) Toplama");
Console.Write("2-) Çıkarma");
Console.Write("3-) Çarpma");
Console.Write("4-) Bölme");
string secim = Console.ReadLine();
Console.Write("Lütfen 1.sayıyı giriniz: ");
int sayi1 = int.Parse(Console.ReadLine());
Console.Write("Lütfen 2.sayıyı giriniz : ");
int sayi2 = int.Parse(Console.ReadLine());
int sonuc;
switch (secim)
{
    case "1":
        sayi1 + sayi2 = sonuc;
        Console.WriteLine("1.sayı ile 2.sayının toplamı = " , sonuc);
        break;
    case "2":
        sayi1 - sayi2 = sonuc;
        Console.WriteLine("1.sayı ile 2.sayının çıkartılması =  " , sonuc);
        break;
    case "3":
        sayi1 * sayi2 = sonuc;
        Console.WriteLine("1.sayı ile 2.sayının çarpımı = " , sonuc);
        break;
    case "4":
        if (sayi2 != 0) {
            sayi1 + sayi2 = sonuc;
            Console.WriteLine("1.sayı ile 2.sayının bölümü = " , sonuc);
            break;
        }
        else
            Console.WriteLine("Bölüm 0 olamaz");
    default:
        Console.WriteLine("Lütfen seçeneklerde olan sayıyı seçiniz.");
        continue;
}
//Burada if else de kullanabiliriz fakat en mantıklı olan switch expression kullanmak ama şu anki değişken yapısını değiştirerek çok daha kısa,okunabilir bir yapı olmuş olur.Ya da şöyle bir
//yapı kullanabiliriz.Fakat böyle bir yapı eklememiz gerekir menü kısmı yerine.
Console.Write("Hangi işlemi yapmak istersiniz(+,/,*,-)");
char islem = char.Parse(Console.ReadLine());
Console.WriteLine(islem = "+" ? sayi1 + sayi2 : (islem = "-" ? sayi1 - sayi2 : (islem = "/" ? sayi1 / sayi2 : sayi1 * sayi2)));
#endregion

