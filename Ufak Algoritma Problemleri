#region Problem 16
//Belirli değer aralığındaki 5in katı olan sayıları recursive fonksiyon ile yazalım.
//Bu problemi döngülerle de çok rahat çözeriz ama amacımız recursive fonksiyonlara alışmak.
int Topla(int baslangic,int bitis)
{
    if( baslangic % 5 == 0)
        return baslangic + Topla(++baslangic, bitis);
    if(baslangic < bitis)
        return Topla(++baslangic,bitis);
    return 0;
}

#endregion

